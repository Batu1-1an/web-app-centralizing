# =============================================================================
# IT Asset Manager - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- Django Core Settings ------------------------------------------------

# Secret key used for cryptographic signing.
# Generate one via: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Debug mode: True for development, False for production.
# Never run with DEBUG=True in production.
DJANGO_DEBUG=True

# Comma-separated list of allowed hostnames/IPs.
# Examples: localhost,127.0.0.1,.yourdomain.com,.onrender.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of trusted origins for CSRF (include scheme + host).
# Required when using load balancers or reverse proxies.
# Examples: http://localhost:8000,https://yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# --- Database Settings ---------------------------------------------------

# Engine: django.db.backends.postgresql (production) or
#         django.db.backends.sqlite3 (local development — no extra config needed)
DB_ENGINE=django.db.backends.postgresql

# PostgreSQL connection details (ignored when using SQLite)
DB_NAME=itassetmanager
DB_USER=itassetmanager
DB_PASSWORD=your-db-password
DB_HOST=db
DB_PORT=5432

# --- Email Settings ------------------------------------------------------

# Email backend: SMTP (production) or console (development — prints to terminal).
# When using console, the SMTP fields below can be left as-is.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SMTP server configuration
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# --- Production Security Settings ----------------------------------------

# Redirect all HTTP traffic to HTTPS when True.
# Enable only when SSL/TLS is configured (requires a reverse proxy or HTTPS termination).
DJANGO_SECURE_SSL_REDIRECT=False

# HTTP Strict-Transport-Security max-age in seconds.
# Start with 0 during initial HTTPS setup, increase gradually (e.g., 3600, 86400, 31536000).
DJANGO_SECURE_HSTS_SECONDS=0
